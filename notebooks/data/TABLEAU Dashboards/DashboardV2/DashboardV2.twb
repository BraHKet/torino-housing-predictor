          </mapsources>
          <datasource-dependencies datasource='federated.1apsjxd0y96tfq1bg6zha0olzafc'>
            <column caption='Prezzo al metro quadro' datatype='real' name='[Calculation_0836239968874496]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[price] / [size_m2]' />
            </column>
            <column caption='Score trasporti minuti' datatype='real' name='[Calculation_0836239969079297]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([minuti_metro] + [minuti_tram] + [minuti_bus]) / 3' />
            </column>
            <column caption='Score_universita' datatype='real' name='[Calculation_0962684260831232]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;  (20 - MIN([tempo_piedi_universita_min], 40))&#13;&#10;  -&#13;&#10;  { FIXED : MIN(20 - MIN([tempo_piedi_universita_min], 40)) }&#13;&#10;)&#13;&#10;/&#13;&#10;(&#13;&#10;  { FIXED : MAX(20 - MIN([tempo_piedi_universita_min], 40)) }&#13;&#10;  -&#13;&#10;  { FIXED : MIN(20 - MIN([tempo_piedi_universita_min], 40)) }&#13;&#10;)&#13;&#10;* 10' />
            </column>
            <column caption='score_trasporti' datatype='real' name='[Calculation_0962684260966401]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;  { FIXED : MAX(MIN([Calculation_0836239969079297], 30)) } - MIN([Calculation_0836239969079297], 30)&#13;&#10;)&#13;&#10;/&#13;&#10;(&#13;&#10;  { FIXED : MAX(MIN([Calculation_0836239969079297], 30)) } - { FIXED : MIN(MIN([Calculation_0836239969079297], 30)) }&#13;&#10;)&#13;&#10;* 10' />
            </column>
            <column caption='Score_qualita' datatype='real' name='[Calculation_0962684263034883]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;  (([luxury_score]*2) + IF [elevator_final] = 1 THEN 1 ELSE 0 END - ([floor]/2))&#13;&#10;  -&#13;&#10;  { FIXED : MIN(([luxury_score]*2) + IF [elevator_final] = 1 THEN 1 ELSE 0 END - ([floor]/2)) }&#13;&#10;)&#13;&#10;/&#13;&#10;(&#13;&#10;  { FIXED : MAX(([luxury_score]*2) + IF [elevator_final] = 1 THEN 1 ELSE 0 END - ([floor]/2)) }&#13;&#10;  -&#13;&#10;  { FIXED : MIN(([luxury_score]*2) + IF [elevator_final] = 1 THEN 1 ELSE 0 END - ([floor]/2)) }&#13;&#10;)&#13;&#10;* 10' />
            </column>
            <column caption='score_locali' datatype='real' name='[Calculation_0962684263120900]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;  [numero_locali] - { FIXED : MIN([numero_locali]) }&#13;&#10;)&#13;&#10;/&#13;&#10;(&#13;&#10;  { FIXED : MAX([numero_locali]) } - { FIXED : MIN([numero_locali]) }&#13;&#10;)&#13;&#10;* 10' />
            </column>
            <column caption='score_prezzo' datatype='real' name='[Calculation_0962684263354373]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;  { FIXED : MAX(MIN([Calculation_0836239968874496], 4000)) } - MIN([Calculation_0836239968874496], 4000)&#13;&#10;)&#13;&#10;/&#13;&#10;(&#13;&#10;  { FIXED : MAX(MIN([Calculation_0836239968874496], 4000)) } - { FIXED : MIN(MIN([Calculation_0836239968874496], 4000)) }&#13;&#10;)&#13;&#10;* 10' />
            </column>
            <column caption='investment_score' datatype='real' name='[Calculation_0962684263481350]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;  (&#13;&#10;    ([Calculation_0962684263120900] * 10)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684263354373] * 10)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684260831232] * 5)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684260966401] * 5)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684263034883] * 2.5)&#13;&#10;  )&#13;&#10;  -&#13;&#10;  { FIXED : MIN(&#13;&#10;    ([Calculation_0962684263120900] * 10)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684263354373] * 10)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684260831232] * 5)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684260966401] * 5)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684263034883] * 2.5)&#13;&#10;  )}&#13;&#10;)&#13;&#10;/&#13;&#10;(&#13;&#10;  { FIXED : MAX(&#13;&#10;    ([Calculation_0962684263120900] * 10)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684263354373] * 10)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684260831232] * 5)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684260966401] * 5)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684263034883] * 2.5)&#13;&#10;  )}&#13;&#10;  -&#13;&#10;  { FIXED : MIN(&#13;&#10;    ([Calculation_0962684263120900] * 10)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684263354373] * 10)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684260831232] * 5)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684260966401] * 5)&#13;&#10;    +&#13;&#10;    ([Calculation_0962684263034883] * 2.5)&#13;&#10;  )}&#13;&#10;)&#13;&#10;* 10' />
            </column>
