            <column caption='Denom' datatype='string' name='[DENOM]' role='dimension' type='nominal' />
            <column caption='Elevator Final' datatype='real' name='[elevator_final]' role='measure' type='quantitative' />
            <column caption='Floor' datatype='real' name='[floor]' role='measure' type='quantitative' />
            <column aggregation='Avg' caption='Lat' datatype='real' name='[lat]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
            <column aggregation='Avg' caption='Lon' datatype='real' name='[lon]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
            <column caption='Luxury Score' datatype='integer' name='[luxury_score]' role='measure' type='quantitative' />
            <column caption='Minuti Bus' datatype='real' name='[minuti_bus]' role='measure' type='quantitative' />
            <column caption='Minuti Metro' datatype='real' name='[minuti_metro]' role='measure' type='quantitative' />
            <column caption='Minuti Tram' datatype='real' name='[minuti_tram]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0962684263120900]' derivation='None' name='[none:Calculation_0962684263120900:ok]' pivot='key' type='ordinal' />
