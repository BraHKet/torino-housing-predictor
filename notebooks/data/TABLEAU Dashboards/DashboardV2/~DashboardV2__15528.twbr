            </column>
            <column caption='Denom' datatype='string' name='[DENOM]' role='dimension' type='nominal' />
            <column datatype='string' name='[Denom (gruppo)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[DENOM]' new-bin='true'>
                <bin default-name='false' value='&quot;Centro&quot;'>
