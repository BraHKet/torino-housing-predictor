          <datasource-dependencies datasource='federated.1apsjxd0y96tfq1bg6zha0olzafc'>
            <column caption='Score trasporti minuti' datatype='real' name='[Calculation_0836239969079297]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([minuti_metro] + [minuti_tram] + [minuti_bus]) / 3' />
            </column>
            <column caption='Score_universita' datatype='real' name='[Calculation_0962684260831232]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='20-([tempo_piedi_universita_min])' />
            </column>
            <column caption='score_trasporti' datatype='real' name='[Calculation_0962684260966401]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='-([Calculation_0836239969079297]/2)' />
            </column>
            <column caption='Score_qualita' datatype='real' name='[Calculation_0962684263034883]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;    ([luxury_score]*2)&#13;&#10;    +&#13;&#10;    IF [elevator_final] = 1 THEN 1 ELSE 0 END&#13;&#10;    -&#13;&#10;    ([floor]/3)&#13;&#10;)' />
            </column>
            <column caption='score_locali' datatype='real' name='[Calculation_0962684263120900]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[numero_locali]*3' />
            </column>
            <column caption='investment_score' datatype='real' name='[Calculation_0962684263481350]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_0962684260831232]&#13;&#10;+&#13;&#10;[Calculation_0962684260966401]&#13;&#10;+&#13;&#10;[Calculation_0962684263034883]&#13;&#10;+&#13;&#10;[Calculation_0962684263120900]' />
